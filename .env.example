# Cartograph configuration
# Copy this to .env and fill in values

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=cartograph
POSTGRES_PASSWORD=cartograph
POSTGRES_DB=cartograph

# Anthropic API key (optional — enables semantic zoom descriptions via LLM)
ANTHROPIC_API_KEY=

# SBERT model (default: all-MiniLM-L6-v2)
# CARTOGRAPH_SBERT_MODEL=all-MiniLM-L6-v2
